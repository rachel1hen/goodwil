---
import { MapPin, MessageCircle, Phone } from "@lucide/astro";
import { business, courses } from "../data/business";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>{business.name}</h2>
      <p>{business.shortDescription}</p>
      <p>
        <strong>{business.status}</strong> | {business.rating} rating from {business.ratingCount} Justdial ratings.
      </p>
    </div>
    <div>
      <h3>Courses</h3>
      <ul class="footer-list">
        {courses.map((course) => <li><a href={course.route}>{course.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h3>Contact</h3>
      <ul class="footer-list">
        <li><a href={`tel:${business.phone}`}><Phone size={15} /> {business.phoneDisplay}</a></li>
        <li>
          <a href={`https://wa.me/${business.whatsapp}`} target="_blank" rel="noopener noreferrer">
            <MessageCircle size={15} /> WhatsApp enquiry
          </a>
        </li>
        <li><MapPin size={15} /> Hingna T Point, Nagpur</li>
      </ul>
    </div>
  </div>
</footer>
